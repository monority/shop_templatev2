# ── HORLOGÉS E-Commerce Template — Environment Variables ──────────────────────
#
# SETUP:
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in your Firebase project values (https://console.firebase.google.com)
#   3. Never commit .env.local — it's already in .gitignore via *.local
#
# The app runs without Firebase (auth/checkout disabled).
# Products are fetched from DummyJSON (no config needed).
# ─────────────────────────────────────────────────────────────────────────────

# Firebase — required for auth, user profiles, and order history
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
